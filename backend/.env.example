# Backend Environment Variables Example
PORT=8000
MONGO_URI=mongodb://localhost:27017/interview_prep_ai
JWT_SECRET=change_me
# Comma-separated if you want multiple custom origins (currently only one is used directly)
# Primary allowed frontend origin (Render production)
# Example: FRONTEND_ORIGIN=https://your-frontend-app.onrender.com
FRONTEND_ORIGIN=http://localhost:5173
# Gemini model configuration (defaults to gemini-1.5-flash-latest if unset)
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-1.5-flash-latest

# mail configs
SUPPROT_EMAIL=syour_support_email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email
SMTP_PASS='your_app_password'
